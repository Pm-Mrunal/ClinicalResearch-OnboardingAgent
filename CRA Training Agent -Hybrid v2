        "jsCode": "const output = $input.first().json.output;\nconst sessionId = $('Extract Inputs').first().json.sessionId;\nconst existingPlan = $('Filter Record by Session').first().json.training_plan || '';\nconst existingLog  = $('Filter Record by Session').first().json.completions_log || '';\n\n// ── 1. Canonical training item names to watch for ──────────────────────────\nconst TRAINING_ITEMS = [\n  { key: 'HIPAA Training',                     pattern: /hipaa/i },\n  { key: 'GCP (CITI)',                          pattern: /good clinical practice|gcp/i },\n  { key: 'Biomedical Investigator (CITI)',      pattern: /biomedical investigator/i },\n  { key: 'HIPS (CITI)',                         pattern: /health information privacy|hips/i },\n  { key: 'Financial COI (CITI)',                pattern: /financial conflict of interest|financial coi/i },\n  { key: 'ACRP Modules',                        pattern: /acrp/i },\n  { key: 'EPIC Training',                       pattern: /\\bepic\\b/i },\n  { key: 'OnCore Training',                     pattern: /oncore/i },\n  { key: 'RedCap Training',                     pattern: /redcap/i },\n  { key: 'iRis Account Setup',                  pattern: /iris|irb account/i },\n  { key: 'Cerner Powertrials Training',         pattern: /cerner/i },\n  { key: 'IATA Category B',                     pattern: /iata.*category b|category b.*iata/i },\n  { key: 'IATA Dry Ice',                        pattern: /iata.*dry ice|dry ice.*iata/i },\n  { key: 'SOP Review (Florence e-Binders)',     pattern: /sop review|florence e-binder/i },\n  { key: 'Onboarding Meeting',                  pattern: /onboarding meeting/i },\n  { key: 'Phlebotomy Skill Refresher',          pattern: /phlebotomy/i },\n  { key: 'C-SSRS Training',                     pattern: /c-ssrs/i },\n  { key: 'Florence e-Consent Training',         pattern: /e-consent/i },\n  { key: 'ClinicalTrials.gov Account Setup',    pattern: /clinicaltrials\\.gov/i },\n  { key: 'PI Dashboard Training',               pattern: /pi dashboard/i },\n  { key: 'Concur Training',                     pattern: /concur/i },\n];\n\n// ── 2. Detect if agent reply signals a completion ──────────────────────────\nconst completionSignal = /complet|finish|done|submitted|logged/i.test(output);\nif (!completionSignal) {\n  return [{ json: { session_id: sessionId, completions_log: existingLog, training_plan: existingPlan, should_update: false } }];\n}\n\n// ── 3. Identify WHICH items were completed from the agent reply ────────────\nconst today = new Date().toISOString().slice(0, 10); // YYYY-MM-DD\nconst newEntries = [];\n\nfor (const item of TRAINING_ITEMS) {\n  if (item.pattern.test(output)) {\n    newEntries.push(`[${today}] ${item.key} — Completed (self-reported)`);\n  }\n}\n\n// Fallback: no specific item matched but reply sounds like a completion\nif (newEntries.length === 0) {\n  newEntries.push(`[${today}] Training item — Completed (self-reported; item unspecified)`);\n}\n\n// ── 4. Append to completions_log (never overwrite) ────────────────────────\nconst separator = existingLog.trim() ? '\\n' : '';\nconst updatedLog = existingLog.trim() + separator + newEntries.join('\\n');\n\n// ── 5. Mark matching items in training_plan ────────────────────────────────\n// Strategy: for each completed item, find its bullet line and append a ✅ tag\nlet updatedPlan = existingPlan;\n\nfor (const item of TRAINING_ITEMS) {\n  if (item.pattern.test(output)) {\n    // Match the bullet line(s) that contain this item name (first occurrence heading)\n    // We look for lines starting with \"- \" that contain the item pattern\n    // and insert a completion marker after the item name on that line\n    const lineRegex = new RegExp(\n      `(- (?=[^\\\\n]*(?:${item.pattern.source}))[^\\\\n]*)`,\n      'i'\n    );\n    if (lineRegex.test(updatedPlan)) {\n      updatedPlan = updatedPlan.replace(lineRegex, (match) => {\n        // Avoid double-marking\n        if (match.includes('✅ COMPLETED')) return match;\n        return match + `  ✅ COMPLETED ${today}`;\n      });\n    }\n  }\n}\n\nreturn [{\n  json: {\n    session_id:      sessionId,\n    completions_log: updatedLog,\n    training_plan:   updatedPlan,\n    should_update:   true\n  }\n}];\n"
